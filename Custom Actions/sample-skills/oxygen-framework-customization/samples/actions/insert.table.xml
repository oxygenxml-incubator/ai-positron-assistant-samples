<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Sample External Author Action: Insert Table
  Demonstrates: InsertFragmentOperation with multi-line XML fragment.
  
  Uses ${caret} editor variable to position cursor after insertion.
-->
<a:authorAction xmlns:a="http://www.oxygenxml.com/ns/author/external-action"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oxygenxml.com/ns/author/external-action 
    http://www.oxygenxml.com/ns/author/external-action/authorAction.xsd"
  id="insert.table2">
  <a:name>Insert Table</a:name>
  <a:description>Insert a simple table with header row</a:description>
  <a:smallIconPath href="/images/Table16.png"/>
  <a:largeIconPath href="/images/Table24.png"/>
  <a:operations>
    <a:operation id="InsertFragmentOperation">
      <a:arguments>
        <a:argument name="fragment"><simpletable>
  <sthead>
    <stentry>${caret}</stentry>
    <stentry/>
    <stentry/>
  </sthead>
  <strow>
    <stentry/>
    <stentry/>
    <stentry/>
  </strow>
  <strow>
    <stentry/>
    <stentry/>
    <stentry/>
  </strow>
</simpletable></a:argument>
      </a:arguments>
    </a:operation>
  </a:operations>
  <a:accelerator>M1 T</a:accelerator>
  <a:accessKey>T</a:accessKey>
  <a:enabledInReadOnlyContext>false</a:enabledInReadOnlyContext>
</a:authorAction>
