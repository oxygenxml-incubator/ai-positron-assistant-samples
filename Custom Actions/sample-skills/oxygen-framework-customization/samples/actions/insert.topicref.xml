<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Sample External Author Action: Insert Topic Reference
  Demonstrates: Using a custom Java operation with XPath condition.
  
  The xpathCondition restricts when the action is enabled based on 
  the current element context (DITA class attributes).
-->
<a:authorAction xmlns:a="http://www.oxygenxml.com/ns/author/external-action"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oxygenxml.com/ns/author/external-action 
    http://www.oxygenxml.com/ns/author/external-action/authorAction.xsd"
  id="insert.topicref">
  <a:name>Insert Topic Reference</a:name>
  <a:description>Insert a reference to an existing topic</a:description>
  <a:largeIconPath href="/images/Topicref24.png"/>
  <a:smallIconPath href="/images/Topicref16.png"/>
  <a:accessKey>R</a:accessKey>
  <a:operations>
    <a:operation id="ro.sync.ecss.extensions.dita.map.topicref.InsertTopicrefOperation">
      <a:xpathCondition>self::*[contains(@class, " map/map ") or contains(@class, " map/topicref ") or contains(@class, " map/relcell ") or contains(@class, " map/relcolspec ")]</a:xpathCondition>
    </a:operation>
  </a:operations>
</a:authorAction>
