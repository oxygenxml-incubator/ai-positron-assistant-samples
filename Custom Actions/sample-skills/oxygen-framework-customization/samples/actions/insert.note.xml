<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Sample External Author Action: Insert Note
  Demonstrates: Multiple operations including SurroundWithFragmentOperation.
  
  The action behavior depends on context:
  - Inside existing note: insert new note after current one
  - Inside body: insert note after current element
  - With selection: surround selection with note
-->
<a:authorAction xmlns:a="http://www.oxygenxml.com/ns/author/external-action"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oxygenxml.com/ns/author/external-action 
    http://www.oxygenxml.com/ns/author/external-action/authorAction.xsd"
  id="note">
  <a:name>Note</a:name>
  <a:description>Insert or surround with a note element</a:description>
  <a:operations>
    <!-- Inside existing note: insert after -->
    <a:operation id="InsertFragmentOperation">
      <a:xpathCondition>ancestor-or-self::note</a:xpathCondition>
      <a:arguments>
        <a:argument name="fragment"><note><p>${caret}</p></note></a:argument>
        <a:argument name="insertLocation">ancestor-or-self::note[1]</a:argument>
        <a:argument name="insertPosition">After</a:argument>
      </a:arguments>
    </a:operation>
    <!-- Inside body: insert after current element -->
    <a:operation id="InsertFragmentOperation">
      <a:xpathCondition>parent::body</a:xpathCondition>
      <a:arguments>
        <a:argument name="fragment"><note><p>${caret}</p></note></a:argument>
        <a:argument name="insertLocation">.</a:argument>
        <a:argument name="insertPosition">After</a:argument>
      </a:arguments>
    </a:operation>
    <!-- Default: surround selection with note -->
    <a:operation id="SurroundWithFragmentOperation">
      <a:arguments>
        <a:argument name="fragment"><note><p>${caret}</p></note></a:argument>
      </a:arguments>
    </a:operation>
  </a:operations>
  <a:accelerator>M1 M2 E</a:accelerator>
  <a:accessKey>O</a:accessKey>
  <a:enabledInReadOnlyContext>false</a:enabledInReadOnlyContext>
</a:authorAction>
