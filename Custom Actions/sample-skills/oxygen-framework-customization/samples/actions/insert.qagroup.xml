<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Sample External Author Action: Insert Q/A Group
  Demonstrates: Simple InsertFragmentOperation with XML fragment.
  
  Place this file in a folder named "{framework-name}_externalAuthorActions" 
  relative to your .exf file.
-->
<a:authorAction xmlns:a="http://www.oxygenxml.com/ns/author/external-action"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oxygenxml.com/ns/author/external-action 
    http://www.oxygenxml.com/ns/author/external-action/authorAction.xsd"
  id="insert.qagroup">
  <a:name>Insert Q/A Group</a:name>
  <a:description>Insert a question and answer group</a:description>
  <a:largeIconPath href="img/InsertQAGroup24.png"/>
  <a:smallIconPath href="img/InsertQAGroup16.png"/>
  <a:operations>
    <a:operation id="InsertFragmentOperation">
      <a:arguments>
        <a:argument name="fragment"><qagroup>
  <question/>
  <answer/>
</qagroup></a:argument>
      </a:arguments>
    </a:operation>
  </a:operations>
  <a:enabledInReadOnlyContext>false</a:enabledInReadOnlyContext>
</a:authorAction>
